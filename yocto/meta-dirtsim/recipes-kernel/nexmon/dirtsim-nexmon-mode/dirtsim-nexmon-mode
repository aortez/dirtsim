#!/bin/sh

set -eu

BACKUP_DIR=/var/lib/nexmon
BACKUP_FW="$BACKUP_DIR/cyfmac43455-sdio-standard.stock.bin"
LIVE_FW=/lib/firmware/cypress/cyfmac43455-sdio-standard.bin
NEXMON_FW=/usr/lib/nexmon/cyfmac43455-sdio-standard.bin
NEXMON_MODULE=/usr/lib/nexmon/brcmfmac.ko
NEXMON_VERSION=6.12.2-nexmon

delete_monitor_interfaces() {
    iw dev | awk '
        $1 == "Interface" { iface = $2 }
        $1 == "type" && $2 == "monitor" { print iface }
    ' | while read -r iface; do
        [ -n "$iface" ] || continue
        ip link set "$iface" down >/dev/null 2>&1 || true
        iw dev "$iface" del >/dev/null 2>&1 || true
    done
}

disconnect_wifi() {
    nmcli device disconnect wlan0 >/dev/null 2>&1 || true
}

release_network_manager() {
    nmcli device set wlan0 managed no >/dev/null 2>&1 || true
}

reclaim_network_manager() {
    nmcli device set wlan0 managed yes >/dev/null 2>&1 || true
}

rescan_wifi() {
    nmcli device wifi rescan ifname wlan0 >/dev/null 2>&1 || true
}

restart_wpa_supplicant() {
    systemctl restart wpa_supplicant >/dev/null 2>&1 || true
    sleep 2
}

stop_wpa_supplicant() {
    systemctl stop wpa_supplicant >/dev/null 2>&1 || true

    i=0
    while [ "$i" -lt 20 ]; do
        if ! systemctl is-active --quiet wpa_supplicant 2>/dev/null; then
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

wait_for_no_p2p_device() {
    i=0
    while [ "$i" -lt 20 ]; do
        if ! iw dev 2>/dev/null | grep -q 'type P2P-device'; then
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

wait_for_network_manager_device_ready() {
    i=0
    while [ "$i" -lt 20 ]; do
        state=$(nmcli -t -f GENERAL.STATE device show wlan0 2>/dev/null | sed -n 's/^GENERAL.STATE://p' || true)
        case "$state" in
            30*|50*|100*)
                return 0
                ;;
        esac
        sleep 1
        i=$((i + 1))
    done
    return 1
}

bring_wlan_down() {
    ip link set wlan0 down >/dev/null 2>&1 || true
}

bring_wlan_up() {
    ip link set wlan0 up >/dev/null 2>&1 || true
}

disable_promiscuous_mode() {
    nexutil -p0 >/dev/null 2>&1 || true
}

disable_monitor_mode() {
    nexutil -m0 >/dev/null 2>&1 || true
}

enable_monitor_mode() {
    nexutil -m2 >/dev/null 2>&1
}

enable_promiscuous_mode() {
    nexutil -p1 >/dev/null 2>&1
}

ensure_backup() {
    mkdir -p "$BACKUP_DIR"
    if [ ! -f "$BACKUP_FW" ]; then
        cp "$LIVE_FW" "$BACKUP_FW"
    fi
}

replace_file() {
    src=$1
    dst=$2

    cp "$src" "$dst"
    chmod 0644 "$dst"
}

loaded_version() {
    cat /sys/module/brcmfmac/version 2>/dev/null || true
}

is_enabled() {
    [ "$(loaded_version)" = "$NEXMON_VERSION" ]
}

require_safe_route() {
    if [ "${DIRTSIM_NEXMON_FORCE:-0}" = "1" ]; then
        return 0
    fi

    if ip route show default | grep -q " dev eth"; then
        return 0
    fi

    echo "Refusing to switch Wi-Fi stacks without an Ethernet default route." >&2
    echo "Set DIRTSIM_NEXMON_FORCE=1 to override." >&2
    exit 1
}

unload_wifi_modules() {
    stop_wpa_supplicant || true
    wait_for_no_p2p_device || true
    bring_wlan_down

    modprobe -r brcmfmac_wcc >/dev/null 2>&1 || true
    modprobe -r brcmfmac >/dev/null 2>&1 || true
}

print_status() {
    version=$(loaded_version)
    if [ -n "$version" ]; then
        echo "loaded_version=$version"
    else
        echo "loaded_version=none"
    fi

    if iw phy 2>/dev/null | grep -q '^[[:space:]]*\* monitor$'; then
        echo "monitor_supported=1"
    else
        echo "monitor_supported=0"
    fi

    if is_enabled; then
        echo "stack=nexmon"
    else
        echo "stack=stock"
    fi
}

enable_stack() {
    require_safe_route

    if is_enabled; then
        print_status
        return 0
    fi

    if [ ! -f "$NEXMON_MODULE" ] || [ ! -f "$NEXMON_FW" ]; then
        echo "Nexmon artifacts are missing from /usr/lib/nexmon." >&2
        exit 1
    fi

    ensure_backup
    delete_monitor_interfaces
    disconnect_wifi
    unload_wifi_modules
    replace_file "$NEXMON_FW" "$LIVE_FW"
    insmod "$NEXMON_MODULE"
    sleep 2
    print_status
}

disable_stack() {
    delete_monitor_interfaces
    disconnect_wifi
    unload_wifi_modules

    if [ -f "$BACKUP_FW" ]; then
        replace_file "$BACKUP_FW" "$LIVE_FW"
    fi

    modprobe brcmfmac
    sleep 2
    print_status
}

enter_mode() {
    require_safe_route
    delete_monitor_interfaces
    disconnect_wifi
    release_network_manager
    enable_stack >/dev/null
    bring_wlan_up
    enable_monitor_mode
    enable_promiscuous_mode
    print_status
}

exit_mode() {
    delete_monitor_interfaces
    disable_monitor_mode
    disable_promiscuous_mode
    bring_wlan_down
    disable_stack >/dev/null
    bring_wlan_up
    reclaim_network_manager
    restart_wpa_supplicant
    wait_for_network_manager_device_ready || true
    rescan_wifi
    print_status
}

case "${1:-status}" in
    enter)
        enter_mode
        ;;
    exit)
        exit_mode
        ;;
    enable)
        enable_stack
        ;;
    disable)
        disable_stack
        ;;
    status)
        print_status
        ;;
    *)
        echo "Usage: dirtsim-nexmon-mode [status|enter|exit|enable|disable]" >&2
        exit 1
        ;;
esac

# A/B partition layout for safe remote updates
# Each rootfs gets its own partition - system updates the inactive one

part /boot --source bootimg-partition --ondisk sda --fstype=vfat --label boot --active --align 4096 --size 150
part / --source rootfs --ondisk sda --fstype=ext4 --label rootfs_a --align 4096 --size 800
part /rescue --source rootfs --ondisk sda --fstype=ext4 --label rootfs_b --align 4096 --size 800
